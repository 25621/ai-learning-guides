{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Docusaurus: Build",
      "type": "shell",
      "command": "npm run build",
      "options": {
        "cwd": "${workspaceFolder}/docusaurus-site"
      },
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "always",
        "clear": true
      }
    },
    {
      "label": "Docusaurus: Stop",
      "type": "shell",
      "command": "pkill -f '[d]ocusaurus start' || true",
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "reveal": "silent"
      }
    },
    {
      "label": "Docusaurus: Start",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}/docusaurus-site"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "docusaurus",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting.*",
          "endsPattern": ".*(Server running|Local:|Docusaurus website is running at:).*"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Docusaurus: Restart",
      "type": "shell",
      "command": "pkill -f '[d]ocusaurus start' || true && npm run start",
      "options": {
        "cwd": "${workspaceFolder}/docusaurus-site"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "docusaurus",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Starting.*",
          "endsPattern": ".*(Server running|Local:|Docusaurus website is running at:).*"
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "label": "Docusaurus: Build and Restart",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Docusaurus: Build",
        "Docusaurus: Restart"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
